{
  "name": "secure-information-hiding-system",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:client": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "start": "NODE_ENV=production tsx server/src/index.ts",
    "test": "vitest run",
    "test:unit": "vitest run tests/steganography.test.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "seed:admin": "tsx server/src/scripts/seedAdmin.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@vitejs/plugin-react": "^5.1.1",
    "argon2": "^0.44.0",
    "bmp-js": "^0.1.0",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-session": "^1.18.2",
    "multer": "^2.0.2",
    "pg": "^8.16.3",
    "pngjs": "^7.0.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router-dom": "^7.9.6",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^5.0.5",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "concurrently": "^9.2.1",
    "jsdom": "^27.2.0",
    "prisma": "^6.19.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.13"
  }
}
